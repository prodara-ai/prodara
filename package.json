{
  "name": "prodara",
  "private": true,
  "version": "0.2.1",
  "description": "Prodara — give your AI a compiler, not a pile of markdown",
  "workspaces": [
    "packages/specification",
    "packages/templates",
    "packages/compiler",
    "packages/cli",
    "packages/lsp",
    "packages/vscode"
