{
  "name": "prodara-vscode",
  "displayName": "Prodara",
  "description": "Language support for Prodara .prd specification files",
  "version": "0.1.0",
  "publisher": "prodara",
  "author": "Prodara Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/prodara-ai/prodara.git",
    "directory": "packages/vscode"
  },
  "homepage": "https://github.com/prodara-ai/prodara/tree/main/packages/vscode#readme",
  "bugs": {
    "url": "https://github.com/prodara-ai/prodara/issues"
  },
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:prd"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "prd",
        "aliases": [
          "Prodara",
          "prd"
        ],
        "extensions": [
          ".prd"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "prd",
        "scopeName": "source.prd",
        "path": "./syntaxes/prd.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "prodara.build",
        "title": "Prodara: Build"
      },
      {
        "command": "prodara.validate",
        "title": "Prodara: Validate"
      },
      {
        "command": "prodara.showGraph",
        "title": "Prodara: Show Product Graph"
      },
      {
        "command": "prodara.showPlan",
        "title": "Prodara: Show Plan"
      },
      {
        "command": "prodara.drift",
        "title": "Prodara: Check Drift"
      },
      {
        "command": "prodara.diff",
        "title": "Prodara: Show Diff"
      },
      {
        "command": "prodara.explain",
        "title": "Prodara: Explain Node"
      },
      {
        "command": "prodara.graphVisualizer",
        "title": "Prodara: Graph Visualizer"
      }
    ],
    "snippets": [
      {
        "language": "prd",
        "path": "./snippets/prd.json"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "package": "vsce package",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^5.7.3"
  }
}
