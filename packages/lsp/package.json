{
  "name": "@prodara/lsp",
  "version": "0.1.0",
  "description": "Language Server Protocol implementation for Prodara .prd files",
  "author": "Prodara Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/prodara-ai/prodara.git",
    "directory": "packages/lsp"
  },
  "homepage": "https://github.com/prodara-ai/prodara/tree/main/packages/lsp#readme",
  "bugs": {
    "url": "https://github.com/prodara-ai/prodara/issues"
  },
  "type": "module",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "prodara",
    "lsp",
    "language-server"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@prodara/compiler": "^0.1.0",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.9",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}
