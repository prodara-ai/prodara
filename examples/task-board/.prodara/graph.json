      "workflows": [
        {
          "id": "board.workflow.move_task",
          "kind": "workflow",
          "name": "move_task",
          "capability": "board.capability.task_tracking",
          "authorization": [
            {
              "actor": "board.actor.member",
              "permissions": [
                "task.update"
              ]
            },
            {
              "actor": "board.actor.lead",
              "permissions": [
                "task.update"
              ]
            }
          ],
          "input": [
            {
              "name": "task_id",
              "type": "uuid"
            },
            {
              "name": "target_status",
              "type": {
                "ref": "board.enum.task_status"
              }
            }
          ],
          "reads": [
            "board.entity.task"
          ],
          "writes": [
            "board.entity.task"
          ],
          "steps": [
            {
              "call": "validate_move"
            },
            {
              "decide": "current_status",
              "branches": [
                {
                  "when": "done",
                  "action": {
                    "fail": "already_done"
                  }
                },
                {
                  "when": "review",
                  "action": {
                    "call": "finalize_task"
                  }
                }
              ]
            },
            {
              "call": "apply_transition"
            }
          ],
          "transitions": [
            {
              "entity": "board.entity.task",
              "field": "status",
              "from": "backlog",
              "to": "in_progress"
            },
            {
              "entity": "board.entity.task",
              "field": "status",
              "from": "in_progress",
              "to": "review"
            },
            {
              "entity": "board.entity.task",
              "field": "status",
              "from": "review",
              "to": "done"
            }
          ],
          "effects": [
            {
              "audit": "Task moved"
            },
            {
              "emit": "board.event.task_moved"
            }
          ],
          "returns": [
            {
              "name": "ok",
              "type": {
                "ref": "board.entity.task"
              }
            },
            {
              "name": "error",
              "type": {
                "ref": "board.enum.move_error"
              }
            }
          ]
        },
        {
          "id": "board.workflow.notify_completion",
          "kind": "workflow",
          "name": "notify_completion",
          "reads": [
            "board.entity.task"
          ],
          "effects": [
            {
              "audit": "Completion notification sent"
            }
          ],
          "returns": [
            {
              "name": "ok",
              "type": "boolean"
            }
          ],
          "trigger": "board.event.task_completed"
        }
